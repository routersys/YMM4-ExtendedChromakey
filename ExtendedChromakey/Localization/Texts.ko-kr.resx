<data name="ExtendedChromaKey_Label" xml:space="preserve"><value>확장 크로마키</value></data>
<data name="GroupName_BasicSettings" xml:space="preserve"><value>기본 설정</value></data>
<data name="GroupName_KeyingMode" xml:space="preserve"><value>키잉 모드</value></data>
<data name="GroupName_KeyingAdjustment" xml:space="preserve"><value>키잉 조정</value></data>
<data name="GroupName_Gradient" xml:space="preserve"><value>그라데이션</value></data>
<data name="GroupName_ColorReplacement" xml:space="preserve"><value>색상 오버레이</value></data>
<data name="GroupName_QualityOptimization" xml:space="preserve"><value>품질 최적화</value></data>
<data name="GroupName_ExceptionSettings" xml:space="preserve"><value>예외 설정</value></data>
